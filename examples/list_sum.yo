# ========================
# List operations in YO
# ========================

use list

make numbers = [10, 20, 30, 40, 50]
say "Original list:"
say numbers

make sum = 0
for each num in numbers {
    sum = sum + num
}

say "Sum of all numbers:"
say sum

say "Count of numbers:"
say list.count(numbers)

say "Sorted:"
say list.sort(numbers)
